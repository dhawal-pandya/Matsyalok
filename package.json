{
  "name": "matsyalok",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "The realm of fish — a steering-behaviour sandbox of emergent collective behaviour.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "balance": "esbuild scripts/balance.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/matsyalok-balance.mjs && node node_modules/.cache/matsyalok-balance.mjs",
    "deploy": "./scripts/deploy-gh-pages.sh",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "dependencies": {
    "uplot": "^1.6.32"
  }
}
